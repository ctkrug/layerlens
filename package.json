{
  "name": "layerlens",
  "version": "0.1.0",
  "description": "Static Dockerfile analyzer: visual layer size + cache-invalidation breakdown with reordering suggestions.",
  "type": "module",
  "license": "MIT",
  "author": "ctkrug",
  "homepage": "https://github.com/ctkrug/layerlens",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/layerlens.git"
  },
  "keywords": [
    "docker",
    "dockerfile",
    "layers",
    "cache",
    "image-size",
    "analyzer",
    "devtools"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
